App.UseLinuxIOREDIR=False
App.AppSettings={}
App.EnvironmentVariables={"DUNE_JWT":"{{FlsServiceAuthToken}}","DUNE_WORLD_TITLE":"{{WorldTitle}}","DUNE_REGION":"{{Region}}","DUNE_WORLD_NAME_OVERRIDE":"{{WorldNameOverride}}","DUNE_HOST_DC_ID":"{{ProviderName}}","DUNE_BIND_IP":"{{$ApplicationIPBinding}}","DUNE_EXTERNAL_IP":"{{PublicIPMode}}","DUNE_MQ_GAME_PORT":"{{$RmqGamePort}}","DUNE_MQ_GAME_MGMT_PORT":"{{$RmqGameHttpPort}}","K8S_POOL_GAME_PORT_BASE":"{{$GamePort}}","DUNE_RELEASE_VERSION":"{{ReleaseVersion}}"}
