Meta.DisplayName=Dune Awakening
Meta.Description=Dune Awakening Dedicated Server
Meta.OS=Linux
Meta.AarchSupport=Unknown
Meta.Arch=x86_64
Meta.Author=CubeCoders Limited
Meta.URL=https://duneawakening.com/
Meta.DisplayImageSource=steam:1172710
Meta.EndpointURIFormat=
Meta.ConfigManifest=duneawakeningconfig.json
Meta.MetaConfigManifest=duneawakeningmetaconfig.json
Meta.ConfigRoot=duneawakening.kvp
Meta.MinAMPVersion=2.7.2.8
Meta.SpecificDockerImage=cubecoders/ampbase:debian
Meta.DockerRequired=True
Meta.DockerBaseReadOnly=False
Meta.ContainerPolicy=Required
Meta.ContainerPolicyReason=This application has special requirements that cannot be safely satisfied directly on a host system.
Meta.ExtraSetupStepsURI=https://ccl.sh/40200
Meta.ResourceUsageInfo=6 CPU cores and 32GB RAM minimum, 8 cores and 64GB recommended
Meta.Prerequisites=[]
Meta.ExtraContainerPackages=["patchelf","openssl","jq","gawk","file","ca-certificates"]
Meta.ConfigReleaseState=MinorIssues
Meta.NoCommercialUsage=False
Meta.ConfigVersion=17
Meta.ReleaseNotes=Fixes shutdown reliability at the root: the stop sequence no longer runs inside the signal handler (where a stale read-timeout could abort it midway) and now completes in order every time. Takes effect next start.
Meta.BreakingReleaseNotes=
Meta.AppConfigId=8d7e92b1-1f4a-4a26-9c7e-fdc3a04b1ce0
Meta.OriginalSource=CubeCoders-AMPTemplates-main
Meta.ImportableExtensions=[]
Meta.AppIsMultiIPAware=True
App.DisplayName=Dune Awakening
