[
    {
        "ConfigFile": "server.cfg",
        "AutoMap": true,
        "ConfigType": "kvp",
        "ConfigFormat": "{0} = {1};",
        "ConfigFormatRegex": "^(?<key>.+?)\\s*=\\s*(?<value>.*?);$"
    },
    {
        "ConfigFile": "battleye/beserver.cfg",
        "ConfigType": "kvp",
        "ConfigFormat": "{0} {1}",
        "Subsections": [
            {
                "Heading": "$root",
                "SettingMappings": {
                    "RConPassword": "$RemoteAdminPassword",
                    "RConPort": "$RCONPort",
                    "RConIP": "$ApplicationIPBinding"
                }
            }
        ]
    }
]
